{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend"
    },
    {
      "id": "@secretlint/secretlint-rule-pattern",
      "options": {
        "patterns": [
          {
            "name": "Google/Gemini API key",
            "pattern": "/AIza[0-9A-Za-z_-]{35}/"
          },
          {
            "name": "Rednote/XHS web_session cookie value",
            "pattern": "/web_session=[0-9a-f]{20,}/i"
          },
          {
            "name": "Real cookie value assigned to a cookie env var",
            "pattern": "/(XHS|BILIBILI)_COOKIE\\s*=\\s*[^\\s\"']{60,}/"
          }
        ]
      }
    }
  ]
}
