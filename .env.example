# chefclaw environment contract — PLACEHOLDER VALUES ONLY (kit rule: this is
# the one env file ever committed; every enforcement layer verifies that).
# Real values live in .env.local (gitignored). Claude cannot create or read
# .env.local — the PreToolUse hook + native deny block .env* by design;
# creating it is a human step (see docs/SETUP.md).
#
# Store model for this self-hosted compose app (adapted from docs/SECURITY.md):
# the kit's "local env" and "host env" stores collapse into .env.local on the
# machine that runs the stack. GitHub Actions secrets currently hold NOTHING —
# CI runs with dummy env only. Every var below is a server-side value: none may
# ever get a client-visible prefix (VITE_*) or appear in the frontend bundle.

# ── API / auth ────────────────────────────────────────────────────────────────
# LEGACY bearer token. M2 replaced per-request bearer auth with Google OAuth +
# opaque server-side sessions (below); the bearer branch is GONE. Kept only
# through the deploy window — give it a fresh value on any real deploy, but it
# no longer gates requests (the session cookie does).
CHEFCLAW_API_TOKEN=change-me

# ── Accounts, OAuth & invites (M2 — multi-user; docs/adr/2026-07-07-m2-*) ─────
# Auth provider: fake (default — CI/dev/golden, no network) | google. On a
# 'vps' deploy (SENTRY_ENVIRONMENT=vps below) "fake" FAILS the boot — a real
# deploy MUST flip this to google (auth.assert_prod_auth_safe, fail-closed).
CHEFCLAW_AUTH_PROVIDER=fake
# Google Cloud OAuth client (a DEPLOY human precondition — create the client,
# set its authorised redirect to {PUBLIC_BASE_URL}/api/auth/google/callback).
# The SECRET is a SERVER secret — NEVER a VITE_* var (Hard Rule 4). Empty while
# the provider is "google" ⇒ ConfigError at boot (no OAuth without creds).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=
# Absolute lifetime (hours) of the opaque server-side sessions (default 30 days).
#SESSION_TTL_HOURS=720

# Transactional email for invites: fake (default — logs the activation link,
# zero network) | ses (AWS SES). On a 'vps' deploy "fake" FAILS the boot (an
# invite that only logs is never delivered) — a real deploy MUST flip to ses.
CHEFCLAW_EMAIL=fake
# The verified SES sender, e.g. "chefclaw <no-reply@yourdomain>". Empty while
# CHEFCLAW_EMAIL=ses ⇒ ConfigError. SES send credentials come from the instance
# IAM role / boto3 chain, not an env key here.
EMAIL_FROM=
SES_REGION=
# Public origin the app builds invite links + the OAuth redirect from, e.g.
# https://yourdomain (NO trailing slash). Empty ⇒ ConfigError at create-invite
# (a localhost invite link is useless once you're hosted).
PUBLIC_BASE_URL=
#INVITE_TTL_HOURS=168
# The ONE seed-admin email: the first Google sign-in whose *verified* email
# equals this adopts the migration-seeded admin row (and the existing recipe
# library). EMPTY ⇒ bootstrap-claim disabled entirely (no "first stranger to
# sign in becomes admin" race). Set it to your own email on deploy.
BOOTSTRAP_ADMIN_EMAIL=

# ── Database (Docker compose) ─────────────────────────────────────────────────
# The app assembles its connection URL from parts — a full URL-with-password
# never exists in any file (docs/LESSONS.md: secretlint trips on
# user:password@host even for placeholders). Defaults suit the local compose
# stack; override only if you change the compose postgres service.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=chefclaw
DB_PASSWORD=chefclaw-local-dev
DB_NAME=chefclaw

# ── Extraction models (lands Phase 2) ─────────────────────────────────────────
# Gemini free tier is TRAINING-ELIGIBLE: public cooking videos only. Paid tier
# is a stated precondition before any personal data flows (docs/SERVICES.md).
GEMINI_API_KEY=your-gemini-key-here
# Fallback adapter (CHEFCLAW_EXTRACTOR=qwen; endpoint region/data-governance
# review is a HUMAN precondition before first real use — docs/SERVICES.md).
DASHSCOPE_API_KEY=
# Qwen model id (config, never hardcoded; re-verify catalog + pricing on change).
#DASHSCOPE_MODEL=qwen3-vl-plus

# ── Platform access (tiered — plan §16.10) ────────────────────────────────────
# Rednote access is TIERED: guest (NO cookie — the default) → hard-isolated
# throwaway cookie (only if guest can't fetch something) → manual file upload.
# The MAIN account's cookie must NEVER be used here, under any circumstances.
# Cookies are session credentials to real accounts — key-grade secrets; the
# cookie and User-Agent must be captured as a matching pair, from a dedicated
# browser profile that has never seen the main account.
XHS_COOKIE=
XHS_USER_AGENT=
# Written BY HAND at every cookie refresh — cookie age is not derivable from
# the cookie string; /api/health warns before the 2–4 week expiry closes.
XHS_COOKIE_SET_DATE=
# Optional — anonymous Bilibili (480p, fine for extraction) is the default.
BILIBILI_COOKIE=

# ── Optional overrides (defaults are right for the compose stack) ────────────
# CHEFCLAW_EXTRACTOR=gemini|fake — compose runs gemini; tests/golden use fake.
#CHEFCLAW_EXTRACTOR=gemini
# Model id is config, never hardcoded (re-verify pricing when changing).
# TIER (M3, docs/adr/2026-07-07-per-user-budget-caps.md): GEMINI_MODEL is the
# GLOBAL default everyone runs (gemini-2.5-flash, free/cheap). GEMINI_PAID_MODEL
# (gemini-2.5-pro) is the PAID tier — higher quality at ~4x input / ~3x output
# token cost (padded rates in chefclaw.spend.GEMINI_PRICING; the budget
# guardrails bound pro spend unchanged). A per-user `users.paid_tier` flag (set
# via PATCH /api/admin/users/{id}/budget) bumps THAT account to the paid model;
# flip GEMINI_MODEL itself to move everyone.
#GEMINI_MODEL=gemini-2.5-flash
#GEMINI_PAID_MODEL=gemini-2.5-pro
# Escalate only if on-screen overlay text is being missed at low.
#GEMINI_MEDIA_RESOLUTION=low
# Set automatically inside compose; only needed for host-run dev loops.
#XHS_SIDECAR_URL=
# Platform-fetch proxy — the M-Deploy Rednote escalation ladder's rungs b/c/d
# (home exit node SOCKS5 / commercial residential proxy / home relay) are all
# this ONE knob (docs/RUNBOOK.md §5). Routes ONLY platform-fetch traffic
# (sidecar detail call, media downloads, short-link resolution, yt-dlp);
# api→sidecar and DB traffic stay direct. Empty = direct, the default.
#CHEFCLAW_FETCH_PROXY=

# ── Cost guardrails — FAIL CLOSED: unset or unparseable ⇒ NO paid calls ──────
MONTHLY_LLM_BUDGET_USD=10
MAX_EXTRACTION_ATTEMPTS_PER_DAY=20

# ── Media retention: keep | discard (source videos are the irreplaceable
#    artifact — Rednote posts get deleted; default keep a low-res copy) ────────
MEDIA_RETENTION=keep

# ── Card covers (V2-F, docs/adr/2026-07-07-cover-system-sprites-and-private-
#    frames.md) — sprite | fake | gemini. DEFAULT `sprite`: every recipe is
#    assigned a curated original dish-sprite id during extraction and rendered
#    inline (zero spend, no illustration job, shippable-safe). `gemini` = the
#    legacy paid text-only illustration (needs GEMINI_API_KEY + a confirmed
#    GEMINI_IMAGE_MODEL/GEMINI_IMAGE_COST_USD); `fake` = canned test blob. ──────
#CHEFCLAW_IMAGE_GENERATOR=sprite
# PRIVATE real-frame covers (a finished-dish still grabbed from the source video
# via ffmpeg). DEFAULT false = pure sprites, no frame ever captured or served.
# This is only the GLOBAL half of a two-gate grant — a frame reaches a viewer
# ONLY when this is true AND that user is owner-granted (real_covers_enabled,
# set via the admin API). Multi-user/public stays sprite-only; a creator frame
# never crosses to an ungranted viewer. Meaningful only in sprite mode.
#CHEFCLAW_REAL_COVERS=false

# ── Tier-2 upload size cap (MB) — an over-cap upload is rejected 413 before it
#    is spooled to disk, so an authed client can't fill the box. Default 500
#    (a few-minute cooking video is tens of MB). Lower it on a small VPS. ──────
#MAX_UPLOAD_MB=500

# ── Observability (V2-A — opt-in by presence; docs/SERVICES.md) ──────────────
# Sentry DSNs are ingest addresses, not credentials — but they still live in
# .env.local per the store model. EMPTY = Sentry never initialises (dev/CI/
# tests send zero events). Backend and frontend can share one project's DSN
# or use two projects. VITE_SENTRY_DSN is baked into the SPA at IMAGE BUILD time
# — under push-based CD (RUNBOOK §4) from a GitHub Actions repo VARIABLE, so this
# .env.local value only matters for a local/manual `up -d --build`. The backend
# runtime SENTRY_DSN below is read here at runtime, unchanged. Server keys are
# never build-args (Hard Rule 4).
SENTRY_DSN=
VITE_SENTRY_DSN=
# Tags every event: local | vps.
SENTRY_ENVIRONMENT=local
# Export at deploy so events carry the release: GIT_SHA=$(git rev-parse --short HEAD)
#GIT_SHA=
# Structured logs: json (default — journald/compose logs) | text (dev console).
#CHEFCLAW_LOG_FORMAT=json
#CHEFCLAW_LOG_LEVEL=INFO

# ── Backups (Phase 4 — scripts/backup.sh, launchd-scheduled; plan §10) ───────
# Where encrypted backup artifacts land. Point this OFF the machine when
# possible (synced/network volume) — a backup beside the data it protects
# only survives software mistakes, not disk loss.
CHEFCLAW_BACKUP_DIR=/path/to/backup/destination
# Symmetric GPG passphrase for backup encryption. Generated ONCE, lives in the
# password manager — NEVER only in this machine's .env.local (a passphrase
# stored solely beside the backups it unlocks is lost with the same disk).
BACKUP_GPG_PASSPHRASE=from-your-password-manager
# 1 (default) also backs up the chefclaw_media volume (retained source videos —
# irreplaceable, currently tiny). Set 0 to skip if the archive outgrows the
# destination; backup.sh prints the media size each run so growth is visible.
CHEFCLAW_BACKUP_INCLUDE_MEDIA=1
